# Chess Brain — content engine secrets
# Copy to .env.local

# LLM
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Embeddings (text-embedding-3-small)
OPENAI_API_KEY=

# Image generation gateway
FAL_KEY=

# Optional direct providers
GOOGLE_AI_API_KEY=

# Scheduler
TIMEZONE=America/New_York

# Content output
OUTPUT_DIR=output
